listening-port=3478
tls-listening-port=5349

listening-ip=0.0.0.0
external-ip=__HAILFREQ_PUBLIC_IP__

min-port=49152
max-port=49999

realm=__HAILFREQ_SERVER_HOSTNAME__
server-name=__HAILFREQ_SERVER_HOSTNAME__

# Long-term credential with shared secret (REST API style — Synapse/LiveKit generate temp creds)
use-auth-secret
static-auth-secret=__TURN_SHARED_SECRET__

total-quota=100
bps-capacity=0
stale-nonce=600

# Security: only relay to/from public addresses
no-multicast-peers
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=100.64.0.0-100.127.255.255

# Hardening
no-cli
no-tlsv1
no-tlsv1_1
fingerprint

log-file=stdout
# SECURITY (L2): 'verbose' intentionally omitted — it logs per-session peer/client
# IPs and timing (call metadata at odds with the privacy model). Re-add only for
# short-lived debugging.
