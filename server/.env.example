# === REQUIRED — set these manually ===

# Public hostname for the server (no protocol, no trailing slash)
HAILFREQ_DOMAIN=radio.example.com

# Operator email (used for Let's Encrypt registration)
HAILFREQ_ADMIN_EMAIL=admin@example.com

# Public IPv4 — used by coturn/LiveKit for ICE candidates
HAILFREQ_PUBLIC_IP=203.0.113.10

# === OIDC — set after registering with CitizenID (see docs/citizenid-setup.md) ===
CITIZENID_CLIENT_ID=
CITIZENID_CLIENT_SECRET=

# === AUTO-GENERATED by scripts/generate-secrets.sh — do not edit manually ===
POSTGRES_PASSWORD=
SYNAPSE_REGISTRATION_SHARED_SECRET=
SYNAPSE_MACAROON_SECRET=
SYNAPSE_FORM_SECRET=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TURN_SHARED_SECRET=
