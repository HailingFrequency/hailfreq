# === REQUIRED — set these manually ===

# Identity domain — what users type to connect (forms part of @user:DOMAIN).
# Served only as a .well-known delegation pointer.
# Can be the apex of a domain (e.g., rpk.chat) or a subdomain.
HAILFREQ_DOMAIN=rpk.chat

# Server hostname — where Synapse + LiveKit actually run.
# The .well-known delegation at HAILFREQ_DOMAIN points to here.
# If you want a single-host setup (no delegation), set this to the same value as HAILFREQ_DOMAIN.
HAILFREQ_SERVER_HOSTNAME=server.rpk.chat

# Operator email (used for Let's Encrypt registration)
HAILFREQ_ADMIN_EMAIL=admin@example.com

# Public IPv4 — used by coturn/LiveKit for ICE candidates
HAILFREQ_PUBLIC_IP=203.0.113.10

# === OIDC — set after registering with CitizenID (see docs/citizenid-setup.md) ===
CITIZENID_CLIENT_ID=
CITIZENID_CLIENT_SECRET=

# === AUTO-GENERATED by scripts/generate-secrets.sh — do not edit manually ===
POSTGRES_PASSWORD=
SYNAPSE_REGISTRATION_SHARED_SECRET=
SYNAPSE_MACAROON_SECRET=
SYNAPSE_FORM_SECRET=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TURN_SHARED_SECRET=
