{
  "name": "hailfreq-client",
  "version": "0.1.0",
  "description": "Privacy-first Matrix desktop client for tactical voice ops",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:windows": "electron-builder --win nsis",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "livekit-client": "^2.19.0",
    "matrix-js-sdk": "^35.0.0",
    "node-global-key-listener": "^0.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
