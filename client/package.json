{
  "name": "hailfreq-client",
  "version": "0.3.0",
  "description": "Privacy-first Matrix desktop client for tactical voice ops",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:windows": "electron-builder --win nsis",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "active-win": "^8.2.0",
    "aws-sdk": "file:./stubs/empty-package",
    "electron-store": "^10.0.0",
    "livekit-client": "^2.19.0",
    "matrix-js-sdk": "^38.2.0",
    "mock-aws-s3": "file:./stubs/empty-package",
    "nock": "file:./stubs/empty-package",
    "node-global-key-listener": "^0.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.49.0",
    "postcss": "^8.4.0",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "tar": "^7.5.11",
    "esbuild": "^0.25.0"
  }
}
